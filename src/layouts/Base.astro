---
import './base.css';
import favicon from './favicon.svg?url';
import gsans from './gsans.woff2?url';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href={favicon} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preload" href={gsans} as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
