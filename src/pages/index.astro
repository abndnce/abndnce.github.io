---
import Base from '../layouts/Base.astro';

const randomTextOptions = [
  'Powered by, and sharing, Mullvad',
  'Powered by swiping with 3 fingers',
  'Powered by Colemak',
  'Powered by Astro',
  'Powered by bigrat.monster',
  'Powered by deconstruction',
];
const randomText = randomTextOptions[Math.floor(Math.random() * randomTextOptions.length)];
---

<Base title="Abundance">
  <h1>
    <strong
      ><svg
        xmlns="http://www.w3.org/2000/svg"
        width="1em"
        height="1em"
        viewBox="0 0 24 24"
        style="display: inline; vertical-align: -0.12em"
        ><path
          stroke="currentColor"
          fill="none"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M 12 9 L 12 2 l -3.5 3.5 M 12 2 l 3.5 3.5 M 15 12 L 22 12 l -3.5 -3.5 M 22 12 l -3.5 3.5 M 9 12 L 2 12 l 3.5 -3.5 M 2 12 l 3.5 3.5 M 12 15 L 12 22 l 3.5 -3.5 M 12 22 l -3.5 -3.5"
        ></path></svg
      >Abundance</strong
    > is working to eliminate website scarcity
  </h1>
  <h2>
    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"
      ><path
        fill="currentColor"
        d="M2 21q-.425 0-.712-.288T1 20t.288-.712T2 19h20q.425 0 .713.288T23 20t-.288.713T22 21zm2-3q-.825 0-1.412-.587T2 16V5q0-.825.588-1.412T4 3h16q.825 0 1.413.588T22 5v11q0 .825-.587 1.413T20 18zm0-2h16V5H4zm0 0V5z"
      ></path></svg
    > Connect tabs to tunnels
  </h2>
  <div class="bentos">
    <a href="https://github.com/0k-web/0k"
      ><strong>0K</strong>Bring your own tunnel instead of relying on a server</a
    >
  </div>
  <h2>
    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"
      ><path
        fill="currentColor"
        d="M5 21q-.425 0-.712-.288T4 20v-1q-.275-.275-.638-.437T3 18v-3q0-.425.288-.712T4 14h1V7q0-1.65 1.175-2.825T9 3t2.825 1.175T13 7v10q0 .825.588 1.413T15 19t1.413-.587T17 17v-7h-1q-.425 0-.712-.288T15 9V6q0-.4.363-.562T16 5V4q0-.425.288-.712T17 3h2q.425 0 .713.288T20 4v1q.275.275.638.438T21 6v3q0 .425-.288.713T20 10h-1v7q0 1.65-1.175 2.825T15 21t-2.825-1.175T11 17V7q0-.825-.587-1.412T9 5t-1.412.588T7 7v7h1q.425 0 .713.288T9 15v3q0 .4-.363.563T8 19v1q0 .425-.288.713T7 21z"
      ></path></svg
    > Build like Abundance builds
  </h2>
  <div class="bentos">
    <a><strong>Coming soon</strong>Host a website across 6 domains</a>
    <a><strong>Coming soon</strong>Talk to your servers no matter where your servers are</a>
    <a href="https://pub-a50359bc057145a29fec81fc5062b2b4.r2.dev/index.html"
      ><strong>Welcome to the Internet</strong>Research interesting domains</a
    >
  </div>
  <h2>
    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"
      ><path
        fill="currentColor"
        d="M1 16v-.575q0-1.475 1.425-1.95T5 13t2.575.475T9 15.425V16zm4-4q-.825 0-1.412-.587T3 10t.588-1.412T5 8t1.413.588T7 10t-.587 1.413T5 12m4.675 1.425q-.3 0-.525-.225t-.225-.525q0-.15.225-.525q.2-.25.275-.55T9.5 11t-.075-.587t-.275-.538q-.1-.125-.162-.262t-.063-.288q0-.325.213-.537t.537-.213q.2 0 .363.113t.287.262q.325.45.5.975T11 11t-.175 1.063t-.5.987q-.125.15-.287.263t-.363.112m2.125 2.15q-.325 0-.55-.212t-.225-.538q0-.15.063-.287t.162-.263q.625-.7.938-1.55T12.5 11t-.312-1.713t-.938-1.537q-.1-.125-.162-.25t-.063-.275q0-.325.213-.55t.537-.225q.175 0 .325.075t.275.2Q13.2 7.65 13.6 8.75T14 11t-.413 2.263t-1.212 2.037q-.125.125-.262.2t-.313.075M15 16v-.575q0-1.475 1.425-1.95T19 13t2.575.475T23 15.425V16zm4-4q-.825 0-1.412-.587T17 10t.588-1.412T19 8t1.413.588T21 10t-.587 1.413T19 12"
      ></path></svg
    > Discord
  </h2>
  <div class="bentos">
    <a href="https://discord.gg/5j665Gq2uz"><strong>Discord</strong>Discord</a>
  </div>
  <p class="text"><em>{randomText}</em></p>
</Base>
<style>
  :global(body) {
    width: min(calc(100% - 3rem), 60rem);
    margin-inline: auto;
    padding-block: 0.5rem;
    justify-content: center;
  }
  h1 {
    font-size: 1.375rem;
    line-height: 1.273;
    font-weight: 400;

    margin-left: -1em;
  }
  h1 > strong {
    font-stretch: 150%;
    letter-spacing: -0.05em;
    color: light-dark(#006940, #b1ffcd);
  }
  h2 {
    font-size: 1rem;
    font-weight: 500;
    font-stretch: 120%;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: -1.25rem;
    margin-block: 1rem 0.25rem;
    color: var(--m3c-primary);
  }
  .bentos {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    margin-left: -1rem;
  }
  .bentos > * {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: 1rem;
    border-radius: 1rem;
    background: var(--m3c-surface-container);
    color: var(--m3c-on-surface);
    transition: background 0.15s;
    font-stretch: 90%;
    &[href] {
      &:hover {
        background: var(--m3c-surface-container-high);
      }
    }
    &:not([href]) {
      opacity: 0.6;
      cursor: default;
    }
  }
  .bentos strong {
    display: block;
    font-weight: 600;
    font-stretch: 120%;
    letter-spacing: -0.02em;
  }
  .text {
    margin-top: 1rem;
  }
</style>
