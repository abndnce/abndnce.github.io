---
import Base from '../layouts/Base.astro';
import Build from './_Build.astro';
---

<Base title="Abundance">
  <h1>
    <strong
      ><svg
        xmlns="http://www.w3.org/2000/svg"
        width="1em"
        height="1em"
        viewBox="0 0 24 24"
        style="display: inline; vertical-align: -0.12em"
        ><path
          stroke="currentColor"
          fill="none"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M 12 9 L 12 2 l -3.5 3.5 M 12 2 l 3.5 3.5 M 15 12 L 22 12 l -3.5 -3.5 M 22 12 l -3.5 3.5 M 9 12 L 2 12 l 3.5 -3.5 M 2 12 l 3.5 3.5 M 12 15 L 12 22 l 3.5 -3.5 M 12 22 l -3.5 -3.5"
        ></path></svg
      >Abundance</strong
    > is working to eliminate website scarcity
  </h1>
  <a class="zerok" href="https://github.com/0k-web/0k"
    ><strong>0K</strong>Use the Internet with your own tunnel, even in the most adverse conditions</a
  >
  <h2>
    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"
      ><path
        fill="currentColor"
        d="M5 21q-.425 0-.712-.288T4 20v-1q-.275-.275-.638-.437T3 18v-3q0-.425.288-.712T4 14h1V7q0-1.65 1.175-2.825T9 3t2.825 1.175T13 7v10q0 .825.588 1.413T15 19t1.413-.587T17 17v-7h-1q-.425 0-.712-.288T15 9V6q0-.4.363-.562T16 5V4q0-.425.288-.712T17 3h2q.425 0 .713.288T20 4v1q.275.275.638.438T21 6v3q0 .425-.288.713T20 10h-1v7q0 1.65-1.175 2.825T15 21t-2.825-1.175T11 17V7q0-.825-.587-1.412T9 5t-1.412.588T7 7v7h1q.425 0 .713.288T9 15v3q0 .4-.363.563T8 19v1q0 .425-.288.713T7 21z"
      ></path></svg
    > Build like Abundance builds
  </h2>
  <Build />
  <h2>
    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"
      ><path
        fill="currentColor"
        d="M4 21q-.825 0-1.412-.587T2 19V5q0-.825.588-1.412T4 3h14q.825 0 1.413.588T20 5v2h1q.425 0 .713.288T22 8t-.288.713T21 9h-1v2h1q.425 0 .713.288T22 12t-.288.713T21 13h-1v2h1q.425 0 .713.288T22 16t-.288.713T21 17h-1v2q0 .825-.587 1.413T18 21zm3-4h3q.425 0 .713-.288T11 16v-2q0-.425-.288-.712T10 13H7q-.425 0-.712.288T6 14v2q0 .425.288.713T7 17m6-7h2q.425 0 .713-.288T16 9V8q0-.425-.288-.712T15 7h-2q-.425 0-.712.288T12 8v1q0 .425.288.713T13 10m-6 2h3q.425 0 .713-.288T11 11V8q0-.425-.288-.712T10 7H7q-.425 0-.712.288T6 8v3q0 .425.288.713T7 12m6 5h2q.425 0 .713-.288T16 16v-4q0-.425-.288-.712T15 11h-2q-.425 0-.712.288T12 12v4q0 .425.288.713T13 17"
      ></path></svg
    > Powered by
  </h2>
  <p>
    <a href="https://pub-a50359bc057145a29fec81fc5062b2b4.r2.dev/index.html"
      >Welcome to the Internet</a
    >, a domain name explorer
  </p>
  <p>
    Our <a href="https://discord.gg/5j665Gq2uz">Discord</a> (we have some open Mullvad spots)
  </p>
</Base>
<style>
  :global(body) {
    width: min(calc(100% - 3rem), 40rem);
    margin-inline: auto;
    padding-block: 0.5rem;
    justify-content: center;
  }
  .spacer {
    flex-grow: 1;
  }
  h1 {
    display: flex;
    align-items: center;
    gap: 0.5rem;

    font-size: 1.375rem;
    line-height: 1.273;
    font-weight: 400;

    margin-left: -1em;
    margin-bottom: 0.25rem;
  }
  h1 > strong {
    font-stretch: 150%;
    letter-spacing: -0.05em;
    color: var(--m3c-primary);
  }
  h2 {
    font-size: 1rem;
    font-weight: 500;
    font-stretch: 120%;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: -1.25rem;
    margin-block: 1rem 0.25rem;
    color: var(--m3c-primary);
  }
  .zerok {
    display: flex;
    flex-direction: column;
    padding: 1rem;
    margin-inline: -1rem;
    border-radius: 1rem;
    background-color: var(--m3c-surface-container-high);
    color: var(--m3c-on-surface);
    transition: 0.15s;
    font-stretch: 90%;
    &[href] {
      &:hover {
        background-color: var(--m3c-primary-container-subtle);
        color: var(--m3c-on-primary-container-subtle);
      }
    }
    strong {
      display: block;
      font-weight: 600;
      font-stretch: 120%;
      letter-spacing: -0.02em;
    }
  }
  p > a {
    color: var(--m3c-primary);
    text-decoration: underline;
  }
</style>
